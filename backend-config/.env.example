# ========================================
# Mail Flow 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ========================================

# ========================================
# 安全密钥配置（必须修改！）
# 使用随机生成的强密码
# 生成命令: openssl rand -hex 32
# ========================================
SECRET_KEY=your-random-256-bit-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ========================================
# 数据库配置
# ========================================
# 本地开发环境
# DATABASE_URI=mysql+pymysql://root:root@localhost:3306/contact_mail

# 生产环境（替换为实际密码）
DATABASE_URI=mysql+pymysql://mailflow:YourStrongPassword123!@localhost:3306/contact_mail_prod

# ========================================
# AWS SES 配置（从 IAM 控制台获取）
# ========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SES_SENDER_EMAIL=noreply@yourdomain.com

# SNS Topic ARN（从 SNS 控制台获取）
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:mailflow-events

# ========================================
# 应用配置
# ========================================

# 邮件发送模式
# true = 模拟发送（开发/测试）
# false = 真实发送（生产）
MOCK_EMAIL_SEND=false

# CORS 配置（生产环境限制为前端域名）
CORS_ORIGINS=https://yourdomain.com

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ========================================
# JWT Token 配置
# ========================================
JWT_ACCESS_TOKEN_EXPIRES=24
JWT_REFRESH_TOKEN_EXPIRES=30

# ========================================
# 可选配置
# ========================================

# 限流配置（需要安装 Flask-Limiter）
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# CSRF 配置
# WTF_CSRF_ENABLED=false
# WTF_CSRF_SECRET_KEY=your-csrf-secret-key

# 应用版本（用于健康检查）
APP_VERSION=1.0.0
BUILD_TIME=2026-04-19
